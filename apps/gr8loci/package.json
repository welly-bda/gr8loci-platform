{
  "name": "gr8loci",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo --port 3005",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:seed": "node --env-file=.env.local --import tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "clean": "rm -rf .next .turbo"
  },
  "dependencies": {
    "@platform/auth": "workspace:*",
    "@platform/design-system": "workspace:*",
    "@prisma/client": "^6.0.0",
    "jose": "^5.9.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@platform/config-eslint": "workspace:*",
    "@platform/config-typescript": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "eslint": "^9.15.0",
    "happy-dom": "^15.11.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "@playwright/test": "^1.49.0",
    "vitest": "^2.1.0"
  },
  "prisma": {
    "seed": "node --env-file=.env.local --import tsx prisma/seed.ts"
  }
}
